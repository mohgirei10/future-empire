#!/usr/bin/env node
var log = require('../log.js');
var cmd = require('commander');
cmd
    .version(require('../package').version)
    .usage('[command] [options]')
		.option('-g, --group [group]', '事业部分组 [\'job\'] ex:l_corp => fa_job_corp', 'job')
		.option('-t, --test [bol]', '是否为测试分支(仅内部测试)');

cmd
  .command('update')
  .description('用远端代码更新本地分支')
  .action(fun_command);

cmd
  .command('commit')
  .description('保存本地代码')
  .action(fun_command);

cmd
  .command('push')
  .description('将本地代码提交到远程分支')
  .action(fun_command);

cmd
  .command('create')
  .description('创建本地分支')
  .action(fun_command);

cmd
  .command('PUSH')
  .description('管理员专用！！将远程分支合并到主干')
  .action(fun_command);

cmd.parse(process.argv);

fun_noMatchCommand(function(){
  log.out('必须加参数（update|commit|push|create|PUSH）\n用法见' + cmd['_name'] + ' -h');
});

function fun_noMatchCommand(callback){
  var hasCommand = /^(update|commit|push|create|PUSH)$/.test(cmd.rawArgs[2]);
  if(!hasCommand){
    callback && callback();
  }
}
function fun_command(){
  var type = [].slice.call(arguments).pop()['_name'];
  var group = 'job';
  var strBranchDic = 'presandbox';
  if(typeof cmd.group != undefined){
    group = cmd.group;
  }
  if(cmd.test){
    log.out('这是测试分支');
    strBranchDic = 'ikun_test';
  }
  // log.out(type, strBranchDic, group);
  var git = require('../core')(type, strBranchDic, group);
  git.fire();
}

