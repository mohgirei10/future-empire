#!/bin/sh

sftpupload(){
  # 获取git的操作人名字
  local username=`git config -l | grep user.name | cut -d = -f 2`
  # 获取更新文件列表，并且把文件名中的空格用'|'代替
  # local files=`echo "$1" | cut -b 4- | cut -d '"' -f 2 | cut -d '>' -f 2 | sed 's/^ //' | tr ' ' '|'`
  local files=`echo "$1" | cut -d '>' -f 2 | cut -d '"' -f 2 | sed 's/^ *//' | sed 's/ *$//' | tr ' ' '|'`
  # 要上传的目录集合
  local paths='';
  # sftp 的上传命令
  local sftp_upload='';
  # 需要创建的目录集合（去重）
  local sftp_mkdir='';
  local file
  for file in $files
  do
    # 把文件名中的'|'替换为' '
    _file=`echo $file | sed 's/|/ /g'`
    # 把文件名中的'|'替换为'\ '
    _trueFile=`echo $file | sed 's/|/\\\\ /g'`
    
    # 如果有目录则需要处理目录
    if [ "`echo $file | grep / `" ]
    then
      # 获得目录 此时目录中的空格还是'|' 没有替换是为了循环方便
      _path=`dirname "$_file" | tr ' ' '|'`

      # 获得真实目录 用于上传文件到指定的目录，空格已经变成'\ '
      _truePath=`dirname "$_file" | sed 's/ /\\\\ /g'`
      
      paths=$paths`echo ;echo $_path`
    else
      _truePath=''
    fi
    # echo `echo $_file | `
    sftp_upload=$sftp_upload`echo ;echo put $_trueFile $_truePath`
  done
  # 将获得的目录 排序去重
  paths=`echo "$paths" | sed '/^$/d' | sort -u`
  # 循环处理目录
  local path
  for path in $paths
  do
    # 将目录中的'/'替换为空格以便循环
    path=`echo $path | sed 's;/; ;g'`
    local dir
    for dir in $path
    do
      # 将'|'还原为'\ '
      dir=`echo $dir | sed 's/|/\\\\ /g'`
      sftp_mkdir=$sftp_mkdir`echo;echo "mkdir "$dir;echo 'cd '$dir;`
    done
    sftp_mkdir=$sftp_mkdir`echo;echo 'cd /'`
  done
  # 用sftp上传文件，并记录log
  local log=`sftp $username@192.168.11.149 << EOF
  $sftp_mkdir
  $sftp_upload
  EOF`
  # 打印log
  echo "`echo "$log" | grep Uploading`"
}

remoteDic='presandbox'
group='job'
# 根据本地分支命名规则 获得远程分支名称，并判断远程分支是否存在
getRemoteBranch () {
  local remoteBranch
  local str_nowBranch=`git branch | grep ^\* | cut -d ' ' -f2`
  echo $str_nowBranch
  local mark=`echo $str_nowBranch | cut -d _ -f 1`
  local remoteMark=''
  case $mark in
    l | la)
      remoteMark='fa'
      ;;
    ls)
      remoteMark='fs'
      ;;
    b | ba)
      remoteMark='ha'
      ;;
    bs)
      remoteMark='hs'
      ;;
    o)
      remoteMark=''
      ;;
  esac
  if [ "$remoteMark" == '' ]; then
    remoteBranch=`echo $str_nowBranch | sed "s/${mark}_//"`
  else
    remoteBranch=`echo $str_nowBranch | sed "s/${mark}/${remoteMark}_${2}/"`
  fi
  echo $remoteBranch
  echo `git branch -a | grep $1/$remoteBranch | wc -l`
}

auto_update(){
  git remote update
  local merge=`git merge --no-ff origin master`
  echo "$merge"
  if [ "`echo "$merge" | grep 'merge failed'`" ]
  then
    echo '合并冲突 请检查'
  fi
  local list_merge_files=`echo "$merge" | grep '|' | cut -d '|' -f 1`
  sftpupload "$list_merge_files"
  if [ bol_remoteBranch != 0 ]; then
    local branch=`git merge --no-ff $remoteDic'/'$str_remoteBranch`
    echo "$branch"
    local list_branch_files=`echo "$branch" | grep '|' | cut -d '|' -f 1`
    sftpupload "$list_branch_files"
  fi
}
auto_commit(){
  local str_commit
  local list_files
  git add -A
  list_files=`git status -s | cut -b 4-`
  getcommit () {
    read -p '输入提交原因:' str_commit
    if [ -z $str_commit ]; then
      getcommit
    fi
  }
  getcommit
  git commit -m $str_commit
  echo '开始上传文件'
  sftpupload "$list_files"
}
auto_push(){
  git push $remoteDic $str_nowBranch':'$str_remoteBranch
}
auto_create(){
  local str_create_branch
  local bol_branch_name
  # 先检测分支是否有修改过的文件，有则不能更换分支
  if [ `git status -s | wc -l` != 0 ] ; then
    echo '当前分支还有未提交的代码，不能切换'
    return
  fi
  getbranchname () {
    read -p '输入新建分支名称:' str_create_branch
    if [ "$str_create_branch" == '' ]; then
      getbranchname
    fi
  }
  getbranchname
  bol_branch_name=`git branch | grep ' '$str_create_branch'$' | wc -l`  

  # 如果有分支，直接切换；没有则创建分支
  if [ $bol_branch_name == 1 ]; then
    git checkout $str_create_branch
    echo '已切换至'$str_create_branch
  else
    git checkout master
    # git pull
    git remote update
    local merge=`git merge --no-ff origin master`
    echo "$merge"
    if [ "`echo "$merge" | grep 'merge failed'`" ]
    then
      echo '合并冲突 请检查'
    fi
    local list_merge_files=`echo "$merge" | grep '|' | cut -d '|' -f 1`
    sftpupload "$list_merge_files"

    git checkout -b $str_create_branch
    echo '创建并切换到'$str_create_branch
  fi
}
auto_sftp(){
  local list_files
  if [ `git status -s | wc -l` != 0 ] ; then
    list_files=`git status -s | cut -b 4-`
    sftpupload "$list_files"
  fi
}



changeGroup(){
  if [ $# > 2 ]; then
    if [ "`echo $@ | grep '\s\-g\s'`" ]; then
      local custom_group="`echo $@ | sed 's/^.*\-g \([[:graph:]]*\)[ [:graph:]]*/\1/' `"
      # 如果-g 后面有参数的话就用其参数
      if [ "`echo $custom_group | grep '^\-'`" == '' ]; then
        group=$custom_group
      # 没有参数就为空
      else
        group=''
      fi 
    fi
    if [ "`echo $@ | grep '\s\-g$'`" ]; then
        group=''
    fi
  fi
  # 如果 没有参数就将分组参数设为空，否则设为需要的
}
# 更换group 主要用于跨项目组的配合，有新思路所以不用了
# 别的项目组的分支用o_区分
# changeGroup $@

# 如果是测试模式，将远端库改为ikun_test
if [ "`echo $@ | grep '\s\-t\s'`" ] || [ "`echo $@ | grep '\s\-t$'`" ]; then
  echo '启动测试模式'
  remoteDic='ikun_test'
fi

arr_remoteStatue=$(getRemoteBranch $remoteDic $group)
# 本地分支名称
str_nowBranch=`echo $arr_remoteStatue | cut -d ' ' -f 1`
# 远程分支名称
str_remoteBranch=`echo $arr_remoteStatue | cut -d ' ' -f 2`
# 目前是否存在远程名称
bol_remoteBranch=`echo $arr_remoteStatue | cut -d ' ' -f 3`

auto_$1



